{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Miftahul Cognitive Identity Protocol",
	"description": "Skema absolut untuk memvalidasi state kognitif, keahlian, dan evolusi identitas digital",
	"type": "object",
	"properties": {
		"metadata": {
			"type": "object",
			"properties": {
				"version": {
					"type": "string",
					"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
				},
				"last_updated": {
					"type": "string",
					"format": "date-time"
				},
				"schema_strictness": {
					"type": "string",
					"enum": [
						"flexible",
						"rigid"
					]
				}
			},
			"required": [
				"version",
				"last_updated"
			]
		},
		"core_identity": {
			"type": "object",
			"properties": {
				"designation": {
					"type": "string"
				},
				"operating_principles": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"principle": {
								"type": "string"
							},
							"definition": {
								"type": "string"
							},
							"enforcement_level": {
								"type": "string",
								"enum": [
									"absolute",
									"contextual"
								]
							}
						},
						"required": [
							"principle",
							"definition"
						]
					}
				}
			},
			"required": [
				"designation",
				"operating_principles"
			]
		},
		"cognitive_state": {
			"type": "object",
			"properties": {
				"technical_matrix": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Keahlian teknis dan tumpukan teknologi operasional."
				},
				"domain_expertise": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Pemahaman domain spesifik, analitik pasar, dan logika algoritmik."
				}
			}
		},
		"digital_legacy_directives": {
			"type": "object",
			"properties": {
				"primary_directives": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"description": "Tujuan makro jangka panjang dan visi penciptaan."
				},
				"financial_parameters": {
					"type": "object",
					"properties": {
						"funding_goals": {
							"type": "string"
						},
						"allocation_strategy": {
							"type": "string"
						}
					}
				}
			}
		},
		"chronicles_and_reflections": {
			"type": "array",
			"description": "Log naratif perjalanan hidup, pencapaian, dan evolusi pemikiran",
			"items": {
				"type": "object",
				"properties": {
					"entry_id": {
						"type": "string"
					},
					"timestamp": {
						"type": "string",
						"format": "date-time"
					},
					"category": {
						"type": "string",
						"enum": [
							"philosophical_shift",
							"historical_analysis",
							"technical_milestone",
							"vision_and_planning"
						]
					},
					"event_context": {
						"type": "string",
						"description": "Fakta objektif dari peristiwa atau subjek yang dipelajari"
					},
					"cognitive_impact": {
						"type": "string",
						"description": "Bagaimana hal ini mengubah atau memperkuat identitas, prinsip, atau tujuan"
					}
				},
				"required": [
					"entry_id",
					"timestamp",
					"category",
					"event_context",
					"cognitive_impact"
				]
			}
		}
	},
	"required": [
		"metadata",
		"core_identity",
		"cognitive_state",
		"digital_legacy_directives",
		"chronicles_and_reflections"
	],
	"additionalProperties": false
}